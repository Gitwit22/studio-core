# Streamline Server - local development env vars
# Copy to .env (this repo ignores .env) and fill in values.

# Required for Firebase Admin SDK:
# Option A (recommended): point to a local service-account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=C:\\path\\to\\firebase-service-account.json

# Option B: inline JSON (harder on Windows quoting)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Option C: base64-encoded JSON (single line)
# FIREBASE_SERVICE_ACCOUNT_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50IiwuLi59

# Other common settings
CLIENT_URL=http://localhost:5173
PORT=3001
JWT_SECRET=dev-secret

# LiveKit (if using)
# LIVEKIT_URL=wss://...
# LIVEKIT_API_KEY=...
# LIVEKIT_API_SECRET=...

# HLS public playback base (Cloudflare Worker or CDN)
# Local dev (wrangler dev): http://localhost:8787/hls
# Production (Cloudflare Worker on your domain): https://cdn.your-domain.com/hls
HLS_PUBLIC_BASE_URL=http://localhost:8787/hls

# ──────────────────────────────────────────────────────────────────────
# Horizon Bot Integration
# ──────────────────────────────────────────────────────────────────────
#
# Outbound (StreamLine → Horizon):
#   HORIZON_CHAT_EVENT_URL  — Horizon receiver for chat events
#   HORIZON_VOICE_EVENT_URL — Horizon receiver for voice/audio events
#
# Inbound (Horizon → StreamLine):
#   POST /api/horizon/bot/events          — webhook receiver (HMAC + bearer)
#   POST /api/rooms/:roomId/chat          — agent posts messages into rooms
#
# Support API (Horizon queries StreamLine):
#   GET /api/horizon/bot/support/status             — health check
#   GET /api/horizon/bot/support/rooms              — list active rooms
#   GET /api/horizon/bot/support/rooms/:roomId      — room detail
#   GET /api/horizon/bot/support/rooms/:roomId/chat — recent chat messages
#
# Auth:
#   All bot endpoints require: Authorization: Bearer <HORIZON_WEBHOOK_SECRET>
#   POST /events also requires: X-Horizon-Signature: sha256=<HMAC-SHA256 of body>
# ──────────────────────────────────────────────────────────────────────
# Outbound chat-event receiver (Horizon meeting-listener skill)
HORIZON_CHAT_EVENT_URL=http://10.0.0.27:3000/api/streamline/chat-event
# Outbound voice-event receiver (Horizon meeting-voice-commands skill)
HORIZON_VOICE_EVENT_URL=http://10.0.0.27:3000/api/streamline/voice-event
# Shared secret — used for:
#   • Bearer token on all bot API requests (Authorization: Bearer <secret>)
#   • HMAC-SHA256 signatures on inbound webhooks (X-Horizon-Signature header)
#   • Bearer token on outbound webhook deliveries
HORIZON_WEBHOOK_SECRET=
# Request timeout in ms (default 5000)
# HORIZON_WEBHOOK_TIMEOUT=5000
# Max retries for transient errors (default 2)
# HORIZON_WEBHOOK_RETRIES=2
